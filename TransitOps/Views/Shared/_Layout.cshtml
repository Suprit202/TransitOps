<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TransitOps</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-gray-900 text-gray-200 font-sans antialiased flex h-screen overflow-hidden">

    <!-- Sidebar Navigation -->
    <aside class="w-64 bg-gray-950 border-r border-gray-800 flex flex-col justify-between h-full shrink-0">
        <div>

            <div class="h-20 flex items-center px-6 border-b border-gray-800">
                <div>
                    <h1 class="text-2xl font-bold text-white tracking-wide">TransitOps</h1>
                    <span class="text-xs text-gray-500 uppercase tracking-widest">Operations</span>
                </div>
            </div>

            <nav class="p-4 space-y-2 mt-2">
                <a href="#" class="block px-4 py-2 text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white rounded transition-colors duration-150">
                    Dashboard
                </a>

                <a asp-controller="Vehicle" asp-action="Index" class="block px-4 py-2 text-sm font-medium text-white bg-gray-800 border-l-4 border-yellow-600 rounded-r transition-colors duration-150">
                    Fleet
                </a>

                <a href="#" class="block px-4 py-2 text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white rounded transition-colors duration-150">
                    Drivers
                </a>
                <a href="#" class="block px-4 py-2 text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white rounded transition-colors duration-150">
                    Trips
                </a>
                <a href="#" class="block px-4 py-2 text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white rounded transition-colors duration-150">
                    Maintenance
                </a>
                <a href="#" class="block px-4 py-2 text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white rounded transition-colors duration-150">
                    Fuel & Expenses
                </a>
                <a href="#" class="block px-4 py-2 text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white rounded transition-colors duration-150">
                    Analytics
                </a>
                <a href="#" class="block px-4 py-2 text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white rounded transition-colors duration-150">
                    Settings
                </a>
            </nav>
        </div>

        <div class="p-4 border-t border-gray-800 bg-gray-900">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <div class="w-8 h-8 rounded-full bg-yellow-600 flex items-center justify-center text-white font-bold text-xs">
                        SA
                    </div>
                    <div class="ml-3">
                        <p class="text-sm font-medium text-white">System Admin</p>
                        <p class="text-xs text-gray-500">Fleet Manager</p>
                    </div>
                </div>
                <a href="#" class="text-xs text-gray-400 hover:text-red-400 transition-colors duration-150">Logout</a>
            </div>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 flex flex-col h-full overflow-y-auto bg-gray-900">
        <header class="h-20 border-b border-gray-800 flex items-center justify-end px-8 shrink-0">
            <div class="flex items-center space-x-4">
                
            </div>
        </header>

        <div class="flex-1 p-8">
            @RenderBody()
        </div>
    </main>

    <!-- Global Delete Modal (Hidden by default) -->
    <div id="globalDeleteModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black bg-opacity-60 transition-opacity">
        <div class="bg-gray-800 rounded-lg shadow-xl border border-gray-700 w-full max-w-md p-6 transform transition-all scale-100">

            <h3 class="text-xl font-semibold text-white mb-4">Confirm Deletion</h3>

            <p class="text-gray-300 mb-6">
                Are you sure you want to delete this <span id="deleteEntityType" class="lowercase"></span>: <span id="deleteItemIdentifier" class="font-bold text-yellow-500"></span>?
                This action cannot be undone.
            </p>

            <div class="flex justify-end space-x-4">
                <button type="button" onclick="closeGlobalDeleteModal()" class="bg-gray-700 hover:bg-gray-600 text-white py-2 px-4 rounded transition duration-150">
                    Cancel
                </button>

                <!-- The generic form that will post to the dynamically injected URL -->
                <form id="globalDeleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="bg-red-600 hover:bg-red-700 text-white py-2 px-4 rounded shadow transition duration-150">
                        Yes, Delete
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Script to handle global modal logic -->
    <script>
        function openGlobalDeleteModal(postUrl, entityType, itemIdentifier) {
        // Set the dynamic text (e.g., "vehicle" and "VAN-05")
        document.getElementById('deleteEntityType').textContent = entityType;
        document.getElementById('deleteItemIdentifier').textContent = itemIdentifier;

        // Set the form action URL dynamically (e.g., /Vehicle/Delete/5)
        document.getElementById('globalDeleteForm').action = postUrl;

        // Show the modal
        document.getElementById('globalDeleteModal').classList.remove('hidden');
        }

        function closeGlobalDeleteModal() {
        // Hide the modal
        document.getElementById('globalDeleteModal').classList.add('hidden');
        }
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>